  {
   "cell_type": "markdown",
   "id": "bf1b1d93",
   "metadata": {},
   "source": [
    "Formation of a Helper Function to help with reading the dataset properly."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "fade82a3",
   "metadata": {},
   "outputs": [],
   "source": [
    "def gzip_reader (path, usecols=None, dtype=str):\n",
    "  return pd.read_csv(path, sep=\"\\t\", compression = \"gzip\", na_values = \"\\\\N\", dtype=dtype, usecols=usecols, low_memory=False)"
   ]
  },
